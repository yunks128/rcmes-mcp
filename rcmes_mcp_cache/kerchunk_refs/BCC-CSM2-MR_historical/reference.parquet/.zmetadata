,"zarr_format":2},"rlds\/.zattrs":{"cell_measures":"area: areacella","cell_methods":"area: time: mean (interval: 5 minutes)","comment":"The surface called 'surface' means the lower boundary of the atmosphere. 'longwave' means longwave radiation. Downwelling radiation is radiation from above. It does not mean 'net downward'. When thought of as being incident on a surface, a radiative flux is sometimes called 'irradiance'. In addition, it is identical with the quantity measured by a cosine-collector light-meter and sometimes called 'vector irradiance'. In accordance with common usage in geophysical disciplines, 'flux' implies per unit area, called 'flux density' in physics.","long_name":"Surface Downwelling Longwave Radiation","missing_value":1.0000000200408773e+20,"original_name":"RLDS","standard_name":"surface_downwelling_longwave_flux_in_air","units":"W m-2","_ARRAY_DIMENSIONS":["time","lat","lon"]},"rsds\/.zarray":{"shape":[23725,600,1440],"chunks":[1,600,1440],"dtype":"<f4","fill_value":1.0000000200408773e+20,"order":"C","compressor":null,"filters":[{"elementsize":4,"id":"shuffle"},{"id":"zlib","level":5}],"zarr_format":2},"rsds\/.zattrs":{"cell_measures":"area: areacella","cell_methods":"area: time: mean (interval: 5 minutes)","comment":"surface solar irradiance for UV calculations","long_name":"Surface Downwelling Shortwave Radiation","missing_value":1.0000000200408773e+20,"original_name":"FSDS","standard_name":"surface_downwelling_shortwave_flux_in_air","units":"W m-2","_ARRAY_DIMENSIONS":["time","lat","lon"]},"sfcWind\/.zarray":{"shape":[23725,600,1440],"chunks":[1,600,1440],"dtype":"<f4","fill_value":1.0000000200408773e+20,"order":"C","compressor":null,"filters":[{"elementsize":4,"id":"shuffle"},{"id":"zlib","level":5}],"zarr_format":2},"sfcWind\/.zattrs":{"cell_measures":"area: areacella","cell_methods":"area: time: mean (interval: 5 minutes)","comment":"near-surface (usually, 10 meters) wind speed.","long_name":"Daily-Mean Near-Surface Wind Speed","missing