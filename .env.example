# RCMES-MCP + MMGIS Stack — Environment Variables
# Copy this file to .env and fill in the required values.
#   cp .env.example .env

# ─── Azure OpenAI (optional — only needed for rcmes-chat CLI) ─────────────
AZURE_OPENAI_ENDPOINT=https://<your-resource>.openai.azure.com/
AZURE_OPENAI_API_KEY=<your-api-key>
AZURE_OPENAI_DEPLOYMENT=gpt-4o
AZURE_OPENAI_API_VERSION=2024-10-21

# ─── Database (PostgreSQL + PostGIS, used by MMGIS) ───────────────────────
DB_NAME=mmgis
DB_USER=mmgis
DB_PASS=change-me-in-production

# ─── MMGIS ────────────────────────────────────────────────────────────────
# URL that MMGIS is reachable at from a web browser
MMGIS_EXTERNAL_URL=http://localhost:2888
MMGIS_PORT=2888
# Default mission name that RCMES tools push layers into
MMGIS_MISSION=climate
# Admin credentials (used on first boot to create the admin account)
MMGIS_ADMIN_USER=admin
MMGIS_ADMIN_PASS=change-me-in-production
# Long-term API token for programmatic access (set to any secure random string)
MMGIS_API_TOKEN=rcmes-dev-token

# ─── TiTiler (COG tile server) ────────────────────────────────────────────
MMGIS_TITILER_EXTERNAL_URL=http://localhost:8080
TITILER_PORT=8080

# ─── RCMES ────────────────────────────────────────────────────────────────
RCMES_PORT=8000
RCMES_SESSION_TTL=2
